<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MA CONCIERGERIE — Conciergerie Airbnb</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --orange: #F47B20;
  --yellow: #F9C846;
  --dark: #1A1208;
  --cream: #FDF8F0;
  --mid: #7A6040;
  --light: #FEF3DC;
  --white: #FFFFFF;
  --radius: 16px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--dark);
  overflow-x: hidden;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 18px 48px;
  background: rgba(253,248,240,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(244,123,32,0.12);
}
.logo { font-family: 'Playfair Display', serif; font-size: 22px; color: var(--dark); text-decoration: none; }
.logo span { color: var(--orange); }
.nav-links { display: flex; gap: 32px; list-style: none; }
.nav-links a { font-size: 14px; font-weight: 400; color: var(--mid); text-decoration: none; transition: color .2s; }
.nav-links a:hover { color: var(--orange); }
.nav-cta {
  background: var(--orange); color: var(--white);
  padding: 10px 22px; border-radius: 99px;
  font-size: 14px; font-weight: 500; text-decoration: none;
  transition: background .2s, transform .15s;
}
.nav-cta:hover { background: #d96a10; transform: scale(1.03); }

/* HERO */
.hero {
  min-height: 100vh;
  display: flex; align-items: center;
  padding: 120px 48px 80px;
  position: relative;
  overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
  background:
    radial-gradient(ellipse 60% 60% at 75% 50%, rgba(249,200,70,0.18) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 20% 80%, rgba(244,123,32,0.12) 0%, transparent 60%);
}
.hero-dot-grid {
  position: absolute; inset: 0; z-index: 0;
  background-image: radial-gradient(circle, rgba(244,123,32,0.15) 1px, transparent 1px);
  background-size: 32px 32px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
}
.hero-content { position: relative; z-index: 1; max-width: 640px; }
.hero-tag {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--light); border: 1px solid rgba(244,123,32,0.3);
  padding: 6px 14px; border-radius: 99px;
  font-size: 13px; color: var(--orange); font-weight: 500;
  margin-bottom: 28px;
  animation: fadeUp .6s ease both;
}
.tag-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--orange); }
h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(42px, 6vw, 72px);
  line-height: 1.08;
  color: var(--dark);
  margin-bottom: 24px;
  animation: fadeUp .7s .1s ease both;
}
h1 em { color: var(--orange); font-style: italic; }
.hero-sub {
  font-size: 17px; font-weight: 300; color: var(--mid);
  line-height: 1.65; margin-bottom: 40px;
  max-width: 480px;
  animation: fadeUp .7s .2s ease both;
}
.hero-btns { display: flex; gap: 14px; flex-wrap: wrap; animation: fadeUp .7s .3s ease both; }
.btn-primary {
  background: var(--orange); color: var(--white);
  padding: 14px 28px; border-radius: 99px;
  font-size: 15px; font-weight: 500; text-decoration: none;
  transition: background .2s, transform .15s;
  display: inline-block;
}
.btn-primary:hover { background: #d96a10; transform: translateY(-2px); }
.btn-secondary {
  background: transparent; color: var(--dark);
  padding: 14px 28px; border-radius: 99px;
  font-size: 15px; font-weight: 400; text-decoration: none;
  border: 1.5px solid rgba(26,18,8,0.2);
  transition: border-color .2s, transform .15s;
  display: inline-block;
}
.btn-secondary:hover { border-color: var(--orange); color: var(--orange); transform: translateY(-2px); }

.hero-visual {
  position: absolute; right: 6%; top: 50%; transform: translateY(-50%);
  z-index: 1; display: flex; flex-direction: column; gap: 14px;
  animation: fadeLeft .8s .4s ease both;
}
.float-card {
  background: var(--white);
  border: 1px solid rgba(244,123,32,0.15);
  border-radius: var(--radius);
  padding: 16px 20px;
  min-width: 220px;
  box-shadow: 0 4px 24px rgba(244,123,32,0.08);
}
.fc-label { font-size: 11px; color: var(--mid); font-weight: 400; margin-bottom: 6px; text-transform: uppercase; letter-spacing: .05em; }
.fc-val { font-size: 22px; font-weight: 500; color: var(--dark); }
.fc-sub { font-size: 12px; color: #639922; margin-top: 2px; }
.fc-row { display: flex; align-items: center; gap: 10px; }
.fc-icon { width: 36px; height: 36px; border-radius: 50%; background: var(--light); display: flex; align-items: center; justify-content: center; font-size: 16px; }
.fc-info { flex: 1; }
.fc-name { font-size: 13px; font-weight: 500; color: var(--dark); }
.fc-detail { font-size: 12px; color: var(--mid); }
.stars { color: var(--yellow); font-size: 13px; }

/* STATS BAR */
.stats-bar {
  background: var(--dark);
  padding: 36px 48px;
  display: flex; justify-content: center; gap: 64px; flex-wrap: wrap;
}
.stat { text-align: center; }
.stat-num { font-family: 'Playfair Display', serif; font-size: 36px; color: var(--yellow); }
.stat-lbl { font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 4px; }

/* SECTION GENERIC */
section { padding: 96px 48px; }
.section-tag {
  display: inline-block;
  font-size: 12px; font-weight: 500; color: var(--orange);
  text-transform: uppercase; letter-spacing: .1em;
  margin-bottom: 16px;
}
.section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 4vw, 48px);
  color: var(--dark); line-height: 1.15;
  margin-bottom: 16px;
}
.section-sub { font-size: 16px; font-weight: 300; color: var(--mid); line-height: 1.6; max-width: 520px; }

/* PROBLEME */
.problems { background: var(--white); }
.prob-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 56px; }
.prob-card {
  background: var(--cream);
  border: 1px solid rgba(244,123,32,0.1);
  border-radius: var(--radius); padding: 28px;
  transition: border-color .2s, transform .2s;
}
.prob-card:hover { border-color: var(--orange); transform: translateY(-4px); }
.prob-icon { font-size: 28px; margin-bottom: 16px; }
.prob-title { font-size: 16px; font-weight: 500; color: var(--dark); margin-bottom: 8px; }
.prob-text { font-size: 14px; color: var(--mid); line-height: 1.6; }

/* SERVICES */
.services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-top: 56px; }
.service-card {
  background: var(--white);
  border: 1px solid rgba(244,123,32,0.12);
  border-radius: var(--radius); padding: 24px;
  text-align: center;
  transition: background .2s, transform .2s;
}
.service-card:hover { background: var(--light); transform: translateY(-3px); }
.svc-icon { font-size: 32px; margin-bottom: 14px; }
.svc-name { font-size: 15px; font-weight: 500; color: var(--dark); margin-bottom: 6px; }
.svc-desc { font-size: 13px; color: var(--mid); line-height: 1.5; }

/* PRICING */
.pricing { background: var(--white); }
.pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 56px; }
.price-card {
  background: var(--cream);
  border: 1.5px solid rgba(244,123,32,0.15);
  border-radius: var(--radius); padding: 28px 24px;
  transition: transform .2s;
  position: relative;
}
.price-card:hover { transform: translateY(-4px); }
.price-card.featured {
  background: var(--dark); border-color: var(--orange);
}
.featured-badge {
  position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
  background: var(--orange); color: var(--white);
  font-size: 11px; font-weight: 500; padding: 4px 14px; border-radius: 99px;
  white-space: nowrap;
}
.price-name { font-size: 13px; font-weight: 500; text-transform: uppercase; letter-spacing: .08em; color: var(--mid); margin-bottom: 14px; }
.price-card.featured .price-name { color: rgba(255,255,255,0.5); }
.price-amount { font-family: 'Playfair Display', serif; font-size: 38px; color: var(--dark); margin-bottom: 4px; }
.price-card.featured .price-amount { color: var(--yellow); }
.price-per { font-size: 12px; color: var(--mid); margin-bottom: 20px; }
.price-card.featured .price-per { color: rgba(255,255,255,0.4); }
.price-features { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.price-features li { display: flex; align-items: flex-start; gap: 8px; font-size: 13px; color: var(--mid); line-height: 1.4; }
.price-card.featured .price-features li { color: rgba(255,255,255,0.7); }
.check { color: var(--orange); font-weight: 500; flex-shrink: 0; }
.price-card.featured .check { color: var(--yellow); }

/* TEMOIGNAGES */
.testimonials { background: var(--dark); }
.testimonials .section-title { color: var(--white); }
.testimonials .section-tag { color: var(--yellow); }
.testi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 56px; }
.testi-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius); padding: 28px;
}
.testi-stars { color: var(--yellow); font-size: 15px; margin-bottom: 14px; }
.testi-text { font-size: 15px; color: rgba(255,255,255,0.75); line-height: 1.65; font-style: italic; margin-bottom: 20px; font-family: 'Playfair Display', serif; }
.testi-author { display: flex; align-items: center; gap: 12px; }
.testi-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--orange); display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 500; color: var(--white); }
.testi-name { font-size: 14px; font-weight: 500; color: var(--white); }
.testi-detail { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 2px; }

/* CONTACT */
.contact { background: var(--cream); }
.contact-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
.contact-info { padding-top: 8px; }
.contact-promise {
  background: var(--light); border-left: 3px solid var(--orange);
  padding: 20px 22px; border-radius: 0 var(--radius) var(--radius) 0;
  margin-top: 32px;
  font-size: 15px; font-style: italic; color: var(--dark); line-height: 1.6;
  font-family: 'Playfair Display', serif;
}
.form-group { margin-bottom: 18px; }
.form-group label { font-size: 13px; font-weight: 500; color: var(--dark); display: block; margin-bottom: 6px; }
.form-group input,
.form-group select,
.form-group textarea {
  width: 100%; padding: 12px 16px;
  background: var(--white);
  border: 1.5px solid rgba(26,18,8,0.12);
  border-radius: 10px; font-size: 14px;
  font-family: 'DM Sans', sans-serif;
  color: var(--dark); outline: none;
  transition: border-color .2s;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { border-color: var(--orange); }
.form-group textarea { resize: vertical; min-height: 100px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.submit-btn {
  width: 100%; padding: 15px;
  background: var(--orange); color: var(--white);
  border: none; border-radius: 99px;
  font-size: 15px; font-weight: 500; cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: background .2s, transform .15s;
  margin-top: 8px;
}
.submit-btn:hover { background: #d96a10; transform: translateY(-2px); }

/* FOOTER */
footer {
  background: var(--dark); color: rgba(255,255,255,0.45);
  padding: 32px 48px; text-align: center; font-size: 13px;
}
footer a { color: var(--orange); text-decoration: none; }

/* ANIMATIONS */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeLeft {
  from { opacity: 0; transform: translateX(32px) translateY(-50%); }
  to   { opacity: 1; transform: translateX(0) translateY(-50%); }
}

/* RESPONSIVE */
@media (max-width: 900px) {
  nav { padding: 16px 24px; }
  .nav-links { display: none; }
  .hero { padding: 100px 24px 60px; }
  .hero-visual { display: none; }
  section { padding: 72px 24px; }
  .stats-bar { padding: 32px 24px; gap: 32px; }
  .contact-wrap { grid-template-columns: 1fr; gap: 40px; }
  footer { padding: 24px; }
}
</style>
</head>
